          "path": "registry/steps/steps-demo.tsx",
          "type": "registry:example"
        }
      ]
    },
    {
      "name": "steps-compact",
      "type": "registry:example",
      "registryDependencies": ["steps"],
      "files": [
        {
          "path": "registry/steps/steps-compact.tsx",
          "type": "registry:example"
        }
      ]
    },
    {
      "name": "steps-clickable",
      "type": "registry:example",
      "registryDependencies": ["steps"],
      "files": [
        {
          "path": "registry/steps/steps-clickable.tsx",
          "type": "registry:example"
        }
      ]
    }
  ]
